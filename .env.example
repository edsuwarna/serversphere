# ServerSphere Configuration
# Copy this to .env and customize before running

# Login credentials (used to create initial admin on first run)
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me

# Web port
DASHBOARD_PORT=8080

# Session secret (change this!)
SECRET_KEY=change-this-to-a-random-secret

# PostgreSQL
POSTGRES_DB=vpsdashboard
POSTGRES_USER=vpsadmin
POSTGRES_PASSWORD=change-me

# OIDC/SSO (optional — leave empty to disable)
OIDC_ENABLED=false
OIDC_NAME=Authentik      # Button text: "Login with Authentik"
OIDC_DISCOVERY_URL=      # https://auth.example.com/application/o/vps-dashboard/.well-known/openid-configuration
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPE=openid profile email
OIDC_AUTO_PROVISION=true # Auto-create users on first SSO login
OIDC_DEFAULT_ROLE=viewer # Role for new SSO users
OIDC_ADMIN_GROUP=        # Group name that maps to admin role (optional)
OIDC_OPERATOR_GROUP=     # Group name that maps to operator role (optional)
